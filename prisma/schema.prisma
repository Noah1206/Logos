generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  orders        Order[]
  conversions   Conversion[]
  knowledge     Knowledge[]
  credits       Int       @default(1)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Order {
  id        String   @id @default(cuid())
  userId    String
  packageId String
  amount    Int
  credits   Int
  status    String   @default("PENDING") // PENDING, PAID, FAILED
  paymentId String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  payment   Payment?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Payment {
  id            String   @id @default(cuid())
  orderId       String   @unique
  paymentId     String   @unique
  transactionId String?
  amount        Int
  status        String
  rawResponse   String?
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model Conversion {
  id            String    @id @default(cuid())
  userId        String
  sourceUrl     String
  sourceType    String    // "youtube_shorts" | "instagram_reel" | "instagram_feed" | "youtube_long" | "pdf"
  platform      String    // "youtube" | "instagram" | "pdf"
  mode          String    // "video-to-blog" | "feed-to-blog" | "study"
  tone          String?
  title         String?
  resultContent String?   @db.Text
  resultJson    Json?
  transcript    String?   @db.Text
  creditUsed    Int       @default(1)
  status        String    @default("COMPLETED")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  knowledge     Knowledge?
  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, mode])
}

model Knowledge {
  id            String    @id @default(cuid())
  conversionId  String    @unique
  userId        String
  summary       String?   @db.Text
  keyConcepts   Json?
  keywords      Json?
  topic         String?
  subtopics     Json?
  createdAt     DateTime  @default(now())
  conversion    Conversion @relation(fields: [conversionId], references: [id], onDelete: Cascade)
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, topic])
  @@index([userId, createdAt(sort: Desc)])
}
