# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here

# Supabase (프레임 이미지 영구 저장)
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Redis (선택 - 큐 시스템용)
REDIS_URL=redis://localhost:6379

# Instagram 우회 (선택 - IP 차단 시 사용)
# 주거용 프록시 URL (예: socks5://user:pass@host:port 또는 http://user:pass@host:port)
PROXY_URL=
# RapidAPI Instagram Downloader 키 (https://rapidapi.com에서 발급)
RAPIDAPI_KEY=
